def limpar_texto(texto: str) -> str:
    texto = str(texto).lower().strip()
    texto = re.sub(r'[^\w\s]', ' ', texto, flags=re.UNICODE)
    texto = re.sub(r'\b\d+\b', ' ', texto)
    return re.sub(r'\s+', ' ', texto).strip()


def construir_perfil(row) -> str:
    """
    Perfil emocional ponderado.
    Sinopse incluída com peso 2 (campo mais rico semanticamente),
    truncada em 300 chars para não dominar o vetor.
    """
    campos = {
        "Sentimento I":  3,
        "Emoção I":      3,
        "Sentimento II": 2,
        "Emoção II":     2,
        "Gênero":        1,
    }
    partes = []
    for campo, peso in campos.items():
        val = limpar_texto(str(row.get(campo, "")))
        if val:
            partes.extend([val] * peso)

    sinopse = str(row.get("Sinopse", "")).strip()
    if sinopse and sinopse not in ("nan", "N/A", ""):
        partes.extend([limpar_texto(sinopse[:300])] * 2)

    return ' '.join(partes)

