@app.route("/recomendar", methods=["POST"])
def rota_recomendar():
    ip = request.remote_addr or "local"
    if not rate_recomendar(ip):
        return jsonify({"erro": "Muitas requisições. Aguarde."}), 429
    body  = request.get_json(force=True)
    query = body.get("query", "").strip()
    if not query:
        return jsonify({"erro": "Query vazia."})
    if detectar_crise(query):
        return jsonify({"crise": True, "mensagem": CRISIS_RESPOSTA})
    emocoes         = detectar_emocoes(query)
    tipo_sentimento = classificar_ambiguidade(query, emocoes)
    label_emocao    = formatar_label_emocoes(emocoes, tipo_sentimento)
    penalizados = livros_penalizados()
    resultados  = recomendar_livros(query, emocoes, tipo_sentimento, top_k=10)
    if not resultados.empty and penalizados:
        resultados = resultados[~resultados["Título do Livro"].isin(penalizados)].reset_index(drop=True)
    if resultados.empty:
        return jsonify({"erro": "Nenhum livro encontrado."})
    def _san(v):
        if isinstance(v, float) and (math.isnan(v) or math.isinf(v)):
            return None
        return v
    livros  = [{k: _san(v) for k, v in row.items()} for row in resultados.to_dict(orient="records")]
    analise = analisar_top_livro(query, livros[0], tipo_sentimento) if livros else ""
    return jsonify({"livros": livros, "emocao": label_emocao, "analise_ia": analise, "ia_habilitada": _API_KEY_VALIDA})

