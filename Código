MODELO_NOME = "paraphrase-multilingual-MiniLM-L12-v2"


def _hash_dataset(df: pd.DataFrame) -> str:
    conteudo = '|'.join(
        str(t) + str(s)
        for t, s in zip(
            df.get("Título do Livro", pd.Series()).fillna(""),
            df.get("Sinopse", pd.Series()).fillna(""),
        )
    )
    return hashlib.md5(conteudo.encode()).hexdigest()


def carregar_modelo_embeddings(df: pd.DataFrame):
    modelo = SentenceTransformer(MODELO_NOME)
    df["perfil_emocional"] = df.apply(construir_perfil, axis=1)
    hash_atual = _hash_dataset(df)

    try:
        with open(CACHE_PATH, "rb") as f:
            cache = pickle.load(f)
        if (cache.get("modelo") == MODELO_NOME and
                cache.get("hash_dataset") == hash_atual):
            print(f"⚡ Embeddings do cache. Shape: {cache['embeddings'].shape}")
            return modelo, cache["embeddings"]
        print("⚠️  Cache desatualizado (dataset mudou). Recomputando...")
    except Exception:
        pass

    print("⏳ Computando embeddings (primeira vez ~30s)...")
    embs = modelo.encode(
        df["perfil_emocional"].tolist(),
        show_progress_bar=True, batch_size=32, normalize_embeddings=True,
    )
    with open(CACHE_PATH, "wb") as f:
        pickle.dump({
            "modelo":       MODELO_NOME,
            "hash_dataset": hash_atual,
            "embeddings":   embs,
        }, f)
    print(f"✅ Embeddings salvos. Shape: {embs.shape}")
    return modelo, embs

