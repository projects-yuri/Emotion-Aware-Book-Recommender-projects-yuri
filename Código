def detectar_crise(texto: str) -> bool:
    """Detecta linguagem de crise ou ideação suicida."""
    texto_lower = texto.lower()
    return any(kw in texto_lower for kw in CRISIS_KEYWORDS)


def detectar_emocoes(texto: str) -> list[tuple[str, float]]:
    """
    word-boundary (\b) evita falsos positivos como "mal" em "maluco".
    Negação detectada por segmento — "não estou feliz" → triste.
    """
    texto_limpo = limpar_texto(texto)
    contagem: dict[str, float] = {}

    segmentos = re.split(r'[,;.]|\b(?:mas|porém|contudo|entretanto|embora)\b',
                         texto_limpo)
    segmentos = [s.strip() for s in segmentos if s and s.strip()]

    for segmento in segmentos:
        palavras_seg = set(segmento.split())
        negado = bool(palavras_seg & NEGACOES)

        for emocao, keywords in EMOCOES_KEYWORDS.items():
            hits = sum(
                1 for kw in keywords
                if re.search(r'\b' + re.escape(kw) + r'\b', segmento)
            )
            if hits == 0:
                continue

            if negado:
                oposto = OPOSTOS.get(emocao)
                if oposto:
                    contagem[oposto] = contagem.get(oposto, 0) + hits * 0.5
            else:
                contagem[emocao] = contagem.get(emocao, 0) + hits

    if not contagem:
        return [("neutro", 1.0)]

    total = sum(contagem.values())
    ordenado = sorted(contagem.items(), key=lambda x: -x[1])
    return [(e, round(h / total, 3)) for e, h in ordenado]


def classificar_ambiguidade(texto: str, emocoes: list[tuple[str, float]]) -> str:
    if len(emocoes) == 1:
        return "simples"
    texto_limpo = limpar_texto(texto)
    # FIX: CONTRASTES agora está definido acima
    tem_contraste = any(c in texto_limpo for c in CONTRASTES)
    diferenca = abs(emocoes[0][1] - emocoes[1][1])
    if tem_contraste and diferenca < 0.35:
        return "contraditório"
    if diferenca < 0.30:
        return "ambíguo"
    return "simples"


def expandir_query_ambigua(texto: str, emocoes: list[tuple[str, float]]) -> list[str]:
    """
    Expande a query aplicando redirecionamento terapêutico:
    - Emoções negativas → busca pelo antídoto emocional
    - Emoções positivas → espelha o sentimento
    Mantém o texto original como âncora semântica leve.
    """
    texto_limpo = limpar_texto(texto)
    queries = []

    for emocao, _ in emocoes[:3]:
        perfil = MAPA_TERAPEUTICO.get(emocao, "")
        if perfil:
            # Antídoto tem peso dominante; texto original entra como contexto leve
            q = perfil + " " + texto_limpo
        else:
            sinonimos = SINONIMOS.get(emocao, "")
            q = (texto_limpo + " " + sinonimos).strip() if sinonimos else texto_limpo
        queries.append(q.strip())

    return queries or [texto_limpo]


def formatar_label_emocoes(emocoes: list[tuple[str, float]], tipo: str) -> str:
    nomes = [e for e, _ in emocoes[:3]]
    base  = " + ".join(nomes)
    if tipo == "contraditório":
        return f"{base} (contraditório)"
    if tipo == "ambíguo":
        return f"{base} (misto)"
    return nomes[0]

