_rate_recomendar: dict[str, list] = defaultdict(list)
_rate_feedback:   dict[str, list] = defaultdict(list)

def _check_rate(cache: dict, ip: str, limite: int, janela_s: int = 60) -> bool:
    agora = time.time()
    cache[ip] = [t for t in cache[ip] if agora - t < janela_s]
    if len(cache[ip]) >= limite:
        return False
    cache[ip].append(agora)
    return True

def rate_recomendar(ip: str) -> bool:
    """Máximo 20 recomendações por minuto por IP."""
    return _check_rate(_rate_recomendar, ip, limite=20)

def rate_feedback(ip: str) -> bool:
    """Máximo 60 feedbacks por minuto por IP."""
    return _check_rate(_rate_feedback, ip, limite=60)

