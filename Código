async function feedback(idx, util) {
  const livro = (window._livros || [])[idx];
  if (!livro) return;

  const titulo = livro["Título do Livro"];

  // Evita duplo envio
  if (feedbackState.get(String(idx)) === util) return;
  feedbackState.set(String(idx), util);

  const resp = await fetch("/feedback", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ titulo, util, query: queryAtual })
  });
  const data = await resp.json();
  if (data.erro) { console.warn("Feedback rejeitado:", data.erro); return; }

  // Atualiza visual em todos os botões (livro #1 e lista expandida)
  const prefixos = [
    ["fb-ok-", "fb-nok-", "fb-msg-"],
    ["outro-ok-", "outro-nok-", null],
  ];

  prefixos.forEach(([idOk, idNok, idMsg]) => {
    const btnOk  = document.getElementById(idOk  + idx);
    const btnNok = document.getElementById(idNok + idx);
    if (btnOk)  { btnOk.classList.toggle("ativo-ok",  util); btnOk.classList.remove("ativo-nok"); }
