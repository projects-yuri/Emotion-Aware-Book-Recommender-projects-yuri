def treinar_classificador(df):
    df_clf   = df[["Gênero", "Emoção II", "Sentimento I"]].dropna()
    contagem = df_clf["Sentimento I"].value_counts()
    df_clf   = df_clf[df_clf["Sentimento I"].isin(contagem[contagem >= 2].index)]
    X = df_clf[["Gênero", "Emoção II"]].apply(
        lambda r: limpar_texto(' '.join(r.astype(str))), axis=1)
    y = df_clf["Sentimento I"]
    pipeline = Pipeline([
        ("tfidf", TfidfVectorizer(ngram_range=(1, 2), min_df=1, max_features=5000)),
        ("clf",   LogisticRegression(max_iter=1000, C=1.0, class_weight="balanced")),
    ])
    n, n_classes = len(df_clf), y.nunique()
    test_n = max(int(n * 0.2), n_classes + 1)
    if n < 10 or test_n >= int(n * 0.6):
        pipeline.fit(X, y)
        print(f"Classificador treinado ({n} amostras, {n_classes} classes).")
    else:
        n_folds = min(3, n // (n_classes + 1))
        if n_folds >= 2:
            try:
                scores = cross_val_score(pipeline, X, y, cv=n_folds, scoring="accuracy")
                print(f"Classificador CV ({n_folds}-fold): {scores.mean():.2f} ± {scores.std():.2f}")
            except Exception as e:
                print(f"Cross-val ignorada: {e}")
        X_tr, _, y_tr, _ = train_test_split(X, y, test_size=test_n, random_state=42, stratify=y)
        pipeline.fit(X_tr, y_tr)
        print(f"Classificador treinado ({n} amostras, {n_classes} classes).")
    return pipeline

